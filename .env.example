# ReviewPulse AI environment variables
# Copy this file to .env and fill in the values needed for your environment.
#
# This template intentionally includes:
# 1. variables used by the current checked-in repository
# 2. placeholders for the planned architecture shown in the project diagrams
#
# Not every variable below is wired into code yet.

# --------------------------------------------------------------------
# App configuration
# --------------------------------------------------------------------
APP_NAME=ReviewPulse AI
APP_ENV=development
LOG_LEVEL=INFO
API_HOST=127.0.0.1
API_PORT=8000
STREAMLIT_SERVER_PORT=8501
API_BASE_URL=http://127.0.0.1:8000

# --------------------------------------------------------------------
# AWS / raw data lake (planned architecture)
# --------------------------------------------------------------------
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
S3_BUCKET_NAME=
S3_RAW_PREFIX=raw
S3_PROCESSED_PREFIX=processed

# --------------------------------------------------------------------
# Airflow / orchestration (planned architecture)
# --------------------------------------------------------------------
AIRFLOW_HOME=
AIRFLOW__CORE__DAGS_FOLDER=
AIRFLOW__CORE__LOAD_EXAMPLES=False

# --------------------------------------------------------------------
# Spark / processing
# --------------------------------------------------------------------
SPARK_MASTER=local[*]
SPARK_APP_NAME=ReviewPulse
SPARK_SQL_SESSION_TIMEZONE=UTC

# --------------------------------------------------------------------
# Local data paths
# These are useful even when cloud storage is not configured.
# --------------------------------------------------------------------
DATA_DIR=./data
RAW_DATA_DIR=./data/raw
PROCESSED_DATA_DIR=./data/processed
PARQUET_INPUT_PATH=./data/normalized_reviews_parquet
PARQUET_OUTPUT_PATH=./data/reviews_with_sentiment_parquet

# --------------------------------------------------------------------
# Snowflake (planned architecture)
# --------------------------------------------------------------------
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_DATABASE=
SNOWFLAKE_SCHEMA=
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_ROLE=

# --------------------------------------------------------------------
# ChromaDB / vector store
# CHROMA_PATH is planned config; the current repository mostly uses a local default.
# --------------------------------------------------------------------
CHROMA_PATH=./data/chromadb_reviews
CHROMA_COLLECTION_NAME=reviewpulse_reviews

# --------------------------------------------------------------------
# Redis cache (planned architecture)
# --------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
REDIS_TTL_SECONDS=3600
REDIS_VECTOR_CACHE_TTL_SECONDS=3600

# --------------------------------------------------------------------
# Embeddings / retrieval
# EMBEDDING_MODEL is a useful planned config, though the current repository uses
# a hardcoded default in most places.
# --------------------------------------------------------------------
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
TOP_K_RESULTS=5

# --------------------------------------------------------------------
# LLM for live grounded chat
# Current checked-in FastAPI code reads ANTHROPIC_*.
# GEMINI_* is included because it appears in the planned architecture.
# --------------------------------------------------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-sonnet-20240229
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
LLM_PROVIDER=anthropic
LLM_REQUEST_TIMEOUT=30
LLM_MAX_RETRIES=2

# --------------------------------------------------------------------
# Ollama batch aspect extraction
# Current POC script reads OLLAMA_HOST.
# --------------------------------------------------------------------
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# --------------------------------------------------------------------
# Sentiment model / NLP pipeline
# These are architecture-level placeholders for the DistilBERT stage.
# --------------------------------------------------------------------
SENTIMENT_MODEL=distilbert-base-uncased-finetuned-sst-2-english
ASPECT_EXTRACTION_ENABLED=true
SENTIMENT_SCORING_ENABLED=true
EMBEDDINGS_ENABLED=true

# --------------------------------------------------------------------
# YouTube data
# youtube-transcript-api can run without this, but the planned architecture
# also references YouTube API based metadata collection.
# --------------------------------------------------------------------
YOUTUBE_API_KEY=
YOUTUBE_VIDEO_IDS=
# Optional public-search mode when you don't want to hand-curate video IDs.
# When YOUTUBE_API_KEY is set, the ingestion uses a built-in broad review-topic
# discovery set and does not depend on these fallback queries.
YOUTUBE_SEARCH_QUERIES=
YOUTUBE_MAX_VIDEOS_PER_QUERY=5
YOUTUBE_TRANSCRIPT_LANGUAGES=en

# --------------------------------------------------------------------
# Amazon / Hugging Face dataset access
# --------------------------------------------------------------------
HUGGINGFACE_TOKEN=
AMAZON_DATASET_NAME=McAuley-Lab/Amazon-Reviews-2023
AMAZON_CATEGORY=Electronics
AMAZON_BATCH_SIZE=10000
AMAZON_MAX_RECORDS=0

# --------------------------------------------------------------------
# Yelp dataset
# --------------------------------------------------------------------
# Directory containing yelp_academic_dataset_review.json and
# yelp_academic_dataset_business.json.
YELP_DATASET_PATH=
# Optional S3 URI prefix or file URI for the same two Yelp Open Dataset files.
# Example: s3://your-bucket/yelp-open-dataset/
YELP_DATASET_S3_URI=

# --------------------------------------------------------------------
# eBay pipeline
# --------------------------------------------------------------------
EBAY_APP_ID=
EBAY_DEV_ID=
EBAY_CERT_ID=
EBAY_SITE_ID=0
EBAY_ENVIRONMENT=production
EBAY_MARKETPLACE_ID=EBAY_US
# Optional keyword search mode.
EBAY_SEARCH_QUERIES=
# Optional category crawl mode. Use one or more category IDs to crawl those
# subtrees, or set EBAY_CRAWL_ALL_CATEGORIES=true to crawl the full marketplace tree.
EBAY_CATEGORY_IDS=
EBAY_CRAWL_ALL_CATEGORIES=false
# Set to 0 to fetch all available results for each configured query.
EBAY_MAX_ITEMS_PER_QUERY=50

# --------------------------------------------------------------------
# iFixit pipeline
# --------------------------------------------------------------------
IFIXIT_BASE_URL=https://www.ifixit.com
IFIXIT_GUIDE_IDS=
# Optional fallback when guide IDs are not specified. Pulls the most recent
# public guides from iFixit's API without requiring credentials.
IFIXIT_MAX_GUIDES=0

# --------------------------------------------------------------------
# Reddit API (POC / stretch)
# Current POC script reads these.
# --------------------------------------------------------------------
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=ReviewPulseAI/1.0 (academic project)

# --------------------------------------------------------------------
# Guardrails / HITL (planned architecture)
# --------------------------------------------------------------------
ENABLE_GUARDRAILS=true
ENABLE_FAKE_DETECTION=false
ENABLE_HITL=false
FAKE_REVIEW_THRESHOLD=0.7
CONFIDENCE_THRESHOLD=0.5
